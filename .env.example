# Rename this file to .env and fill in your values.
# Never commit .env to GitHub — it contains your secret token.

# Your Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_token_here

# ID of the channel where auto-posts will be sent
# Right-click any channel in Discord → "Copy Channel ID" (requires Developer Mode)
NEWS_CHANNEL_ID=your_channel_id_here

# How often (in minutes) to check for new transactions (default: 30)
CHECK_INTERVAL_MINUTES=30
